// Paste into your Waybar config and add "custom/hypr-spellbook-swap" to a
// modules list, for example after "hyprland/workspaces". The exec is the
// command that `make install` puts on your PATH at ~/.local/bin.
"custom/hypr-spellbook-swap": {
    "exec": "hypr-spellbook-swap-waybar",
    "return-type": "json",
    "signal": 8,
    "tooltip": true,
    "format": "{}"
}
