// Paste into your Waybar config and add "custom/hypr-layout" to a modules list
// (e.g. after "hyprland/workspaces"). Replace the exec path with the absolute
// path to your clone.
"custom/hypr-layout": {
    "exec": "/absolute/path/to/hypr-spellbook-swap/scripts/waybar-layout.sh",
    "return-type": "json",
    "signal": 8,
    "tooltip": true,
    "format": "{}"
}
